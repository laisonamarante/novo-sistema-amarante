              { key:'nome', label:'Descrição', required:true },
              { key:'ordem', label:'Ordem', type:'number' },
            ]} />
        )}

        {/* ─── ETAPAS ──────────────────── */}
        {aba === 'etapas' && (
          <CadSimples label="Etapa"
            listarQuery={trpc.cadastros.etapas.listar.useQuery({})}
