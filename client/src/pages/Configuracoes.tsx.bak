              { key:'nome', label:'Descrição', required:true },
            ]} />
        )}

        {/* ─── FLUXOS ──────────────────── */}
        {aba === 'fluxos' && <FluxosTab />}

        {/* ─── SITUAÇÕES ───────────────── */}
