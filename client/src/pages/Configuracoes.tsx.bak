import { useState } from 'react'
import { useSearchParams, Link } from 'react-router-dom'
import { trpc } from '../lib/trpc'
import { PageHeader, Card, Button, Input, Select, Table, Loading, Modal, Tabs } from '../components/ui'
import { Plus, Trash2, Settings, Pencil } from 'lucide-react'

/* ─── CadSimples genérico (com EDITAR) ─────────────────────────── */
function CadSimples({ label, listarQuery, criarMutation, editarMutation, excluirMutation, campos, extraColumns }: {
  label: string
  listarQuery: any
  criarMutation: any
  editarMutation?: any
  excluirMutation?: any
  campos: { key: string; label: string; required?: boolean; type?: string; options?: {value:any;label:string}[]; half?: boolean }[]
  extraColumns?: { key: string; label: string; render?: (item:any) => any }[]
}) {
  const [modal, setModal] = useState(false)
  const [editId, setEditId] = useState<number|null>(null)
  const [form, setForm]   = useState<Record<string,any>>({})
  const { data, isLoading, refetch } = listarQuery

  const criar = criarMutation({ onSuccess: () => { setModal(false); refetch(); setForm({}); setEditId(null) } })
  const editar = editarMutation?.({ onSuccess: () => { setModal(false); refetch(); setForm({}); setEditId(null) } })
  const excluir = excluirMutation?.({ onSuccess: () => refetch() })

  function set(k:string,v:any) { setForm(f=>({...f,[k]:v})) }

  function openEdit(item: any) {
    if (!editarMutation) return
    const f: Record<string,any> = {}
    campos.forEach(c => { if (item[c.key] !== undefined && item[c.key] !== null) f[c.key] = item[c.key] })
    setForm(f)
    setEditId(item.id)
    setModal(true)
  }

  function openCreate() {
    setForm({})
    setEditId(null)
    setModal(true)
  }

  function handleSave() {
    if (editId && editar) {
      editar.mutate({ id: editId, ...form })
    } else {
      criar.mutate(form)
    }
  }

  // Visible columns in table: first 5 campos + extras
  const tableCampos = campos.slice(0, 5)
  const allHeaders = [...tableCampos.map(c=>c.label), ...(extraColumns||[]).map(c=>c.label), 'Ações']

  // Group campos in rows of 2 for forms with many fields
  const manyFields = campos.length > 5

  return (
    <div>
      <div className="flex justify-end mb-3">
        <Button size="sm" onClick={openCreate}><Plus size={13}/> Novo {label}</Button>
      </div>
      {isLoading ? <Loading/> : (
        <Table headers={allHeaders} empty={!data?.length ? 'Nenhum registro.' : undefined}>
          {data?.map((item:any) => (
            <tr key={item.id} className="hover:bg-gray-50 cursor-pointer" onDoubleClick={() => openEdit(item)}>
              {tableCampos.map(c => (
                <td key={c.key} className="px-4 py-2 text-sm text-gray-700">
                  {c.options ? (c.options.find(o => String(o.value) === String(item[c.key]))?.label || item[c.key] || '—') : (item[c.key] || '—')}
                </td>
              ))}
              {(extraColumns||[]).map(c => <td key={c.key} className="px-4 py-2 text-sm text-gray-700">{c.render ? c.render(item) : (item[c.key]||'—')}</td>)}
              <td className="px-4 py-2">
                <div className="flex gap-1">
                  {editarMutation && (
                    <Button size="sm" variant="ghost" onClick={() => openEdit(item)}><Pencil size={13} className="text-blue-500"/></Button>
                  )}
                  {excluir && (
                    <Button size="sm" variant="ghost" onClick={() => { if (confirm(`Excluir ${label}?`)) excluir.mutate({ id: item.id }) }}><Trash2 size={13} className="text-red-500"/></Button>
                  )}
                </div>
              </td>
            </tr>
          ))}
        </Table>
      )}
      <Modal open={modal} title={editId ? `Editar ${label}` : `Novo ${label}`} onClose={() => { setModal(false); setEditId(null) }}>
        <div className={manyFields ? "grid grid-cols-2 gap-3" : "space-y-3"}>
          {campos.map(c => (
            <div key={c.key} className={c.half === false ? 'col-span-2' : ''}>
              {c.options ? (
                <Select label={`${c.label}${c.required?' *':''}`} value={form[c.key]??''} onChange={e=>set(c.key, c.type==='number' ? Number(e.target.value) : e.target.value)} options={c.options} placeholder="Selecione..." />
              ) : (
                <Input label={`${c.label}${c.required?' *':''}`} type={c.type||'text'} value={form[c.key]??''} onChange={e=>set(c.key, c.type==='number' ? Number(e.target.value) : e.target.value)} />
              )}
            </div>
          ))}
        </div>
        <div className="flex gap-3 pt-4">
          <Button className="flex-1 justify-center" onClick={handleSave} loading={criar.isPending || editar?.isPending}>
            {editId ? 'Salvar Alterações' : 'Criar'}
          </Button>
          <Button variant="secondary" className="flex-1 justify-center" onClick={() => { setModal(false); setEditId(null) }}>Cancelar</Button>
        </div>
      </Modal>
    </div>
  )
}

/* ─── UF OPTIONS ─────────────────────────────────────────────── */
const UFS = ['AC','AL','AM','AP','BA','CE','DF','ES','GO','MA','MG','MS','MT','PA','PB','PE','PI','PR','RJ','RN','RO','RR','RS','SC','SE','SP','TO'].map(u=>({value:u,label:u}))

/* ─── CONFIGURAÇÕES PRINCIPAL ──────────────────────────────────── */
export function Configuracoes() {
  const [searchParams] = useSearchParams()
  const defaultTab = searchParams.get('tab') || 'bancos'
  const [aba, setAba] = useState(defaultTab)

  const abas = [
    { key: 'bancos',          label: 'Bancos' },
    { key: 'agencias',        label: 'Agências' },
    { key: 'modalidades',     label: 'Modalidades' },
    { key: 'fluxos',          label: 'Fluxos' },
    { key: 'situacoes',       label: 'Situações' },
    { key: 'etapas',          label: 'Etapas' },
    { key: 'documentos',      label: 'Documentos' },
    { key: 'construtoras',    label: 'Construtoras' },
    { key: 'empreendimentos', label: 'Empreendimentos' },
    { key: 'imobiliarias',    label: 'Imobiliárias' },
    { key: 'corretores',      label: 'Corretores' },
    { key: 'parceiros',       label: 'Parceiros' },
    { key: 'subestabelecidos',label: 'Subestabelecidos' },
    { key: 'imoveis',         label: 'Imóveis' },
    { key: 'simuladores',     label: 'Simuladores' },
    { key: 'finEmpresas',     label: 'Empresas' },
    { key: 'finContas',       label: 'Contas Bancárias' },
    { key: 'finFornecedores', label: 'Fornecedores' },
    { key: 'finDevedores',    label: 'Devedores' },
    { key: 'finTipoDespesas', label: 'Tipos Despesa' },
    { key: 'finTipoReceitas', label: 'Tipos Receita' },
    { key: 'finNaturezas',    label: 'Naturezas' },
  ]

  // Dados auxiliares para selects
  const bancosQ = trpc.cadastros.bancos.listar.useQuery(undefined, { enabled: ['agencias','finContas'].includes(aba) })
  const fluxosQ = trpc.cadastros.fluxos.listar.useQuery(undefined, { enabled: ['etapas','documentos','modalidades'].includes(aba) })
  const situacoesQ = trpc.cadastros.situacoes.listar.useQuery(undefined, { enabled: aba === 'etapas' })
  const construtorasQ = trpc.cadastros.construtoras.listar.useQuery(undefined, { enabled: aba === 'empreendimentos' })
  const imobiliariasQ = trpc.cadastros.imobiliarias.listar.useQuery(undefined, { enabled: aba === 'corretores' })
  const parceirosQ = trpc.cadastros.parceiros.listar.useQuery(undefined, { enabled: ['corretores','imobiliarias','subestabelecidos'].includes(aba) })
  const empresasQ = trpc.cadastros.finEmpresas.listar.useQuery(undefined, { enabled: aba === 'finContas' })
  const usuariosQ = trpc.cadastros.usuarios.listar.useQuery(undefined, { enabled: ['construtoras','imobiliarias','corretores','parceiros'].includes(aba) })

  const encaminhamentoOpts = ['CENOP','SICOB','CEHOP','INTERCERVICE','FUNCHAL','FINTECH','ITAÚ'].map(v=>({value:v,label:v}))
  const tipoPixOpts = ['CPF','Celular','Email','Aleatória'].map(v=>({value:v,label:v}))
  const tipoImovelOpts = ['Residencial','Comercial','Terreno','Galpão'].map(v=>({value:v,label:v}))
  const tipoEmpreendOpts = ['Comercial','Residencial'].map(v=>({value:v,label:v}))
  const tipoSimOpts = ['Simulador','Portal'].map(v=>({value:v,label:v}))

  return (
    <div>
      <PageHeader title="Configurações" />
      <Card className="p-5">
        <Tabs active={aba} onChange={setAba} tabs={abas} />

        <div key={aba}>
        {/* ─── BANCOS ─────────────────────── */}
        {aba === 'bancos' && (
          <CadSimples label="Banco"
            listarQuery={trpc.cadastros.bancos.listar.useQuery()}
            criarMutation={(opts:any) => trpc.cadastros.bancos.criar.useMutation(opts)}
            editarMutation={(opts:any) => trpc.cadastros.bancos.editar.useMutation(opts)}
            excluirMutation={(opts:any) => trpc.cadastros.bancos.excluir.useMutation(opts)}
            campos={[
              { key:'nome', label:'Nome', required:true },
              { key:'encaminhamento', label:'Encaminhamento', options: encaminhamentoOpts },
              { key:'remuneracao', label:'Remuneração (%)' },
            ]} />
        )}

        {/* ─── AGÊNCIAS ─────────────────── */}
        {aba === 'agencias' && (
          <CadSimples label="Agência"
            listarQuery={trpc.cadastros.agencias.listar.useQuery({})}
            criarMutation={(opts:any) => trpc.cadastros.agencias.criar.useMutation(opts)}
            editarMutation={(opts:any) => trpc.cadastros.agencias.editar.useMutation(opts)}
            excluirMutation={(opts:any) => trpc.cadastros.agencias.excluir.useMutation(opts)}
            campos={[
              { key:'nome', label:'Nome', required:true },
              { key:'bancoId', label:'Banco', type:'number', options: (bancosQ.data||[]).map((b:any)=>({value:b.id,label:b.nome})) },
              { key:'codigo', label:'Número' },
              { key:'cidade', label:'Cidade' },
              { key:'uf', label:'UF', options: UFS },
            ]} />
        )}

        {/* ─── MODALIDADES ─────────────── */}
        {aba === 'modalidades' && (
          <CadSimples label="Modalidade"
            listarQuery={trpc.cadastros.modalidades.listar.useQuery()}
            criarMutation={(opts:any) => trpc.cadastros.modalidades.criar.useMutation(opts)}
            editarMutation={(opts:any) => trpc.cadastros.modalidades.editar.useMutation(opts)}
            excluirMutation={(opts:any) => trpc.cadastros.modalidades.excluir.useMutation(opts)}
