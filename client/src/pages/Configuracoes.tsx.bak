              { key:'ordem', label:'Ordem', type:'number' },
              { key:'tolerancia', label:'Dias permanência', type:'number' },
              { key:'situacaoId', label:'Situação', type:'number', options: (situacoesQ.data||[]).map((s:any)=>({value:s.id,label:s.nome})) },
            ]} />
        )}

        {/* ─── DOCUMENTOS ──────────────── */}
        {aba === 'documentos' && (
          <CadSimples label="Tipo de Documento"
            listarQuery={trpc.cadastros.documentosTipos.listar.useQuery()}
