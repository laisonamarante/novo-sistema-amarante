              { key:'nome', label:'Descrição', required:true },
              { key:'ordem', label:'Ordem', type:'number' },
            ]} />
        )}

        {/* ─── CONSTRUTORAS ────────────── */}
        {aba === 'construtoras' && (
          <CadSimples label="Construtora"
            listarQuery={trpc.cadastros.construtoras.listar.useQuery()}
            criarMutation={(opts:any) => trpc.cadastros.construtoras.criar.useMutation(opts)}
            editarMutation={(opts:any) => trpc.cadastros.construtoras.editar.useMutation(opts)}
            excluirMutation={(opts:any) => trpc.cadastros.construtoras.excluir.useMutation(opts)}
            campos={[
              { key:'nome', label:'Nome', required:true },
              { key:'cnpj', label:'CNPJ' },
              { key:'contato', label:'Contato' },
              { key:'fone', label:'Fone' },
              { key:'fone2', label:'Fone 2' },
              { key:'email', label:'E-mail' },
              { key:'endereco', label:'Endereço' },
              { key:'numero', label:'Número' },
              { key:'bairro', label:'Bairro' },
              { key:'cidade', label:'Cidade' },
